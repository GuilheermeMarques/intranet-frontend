  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.417.0",
    "@nestjs/common": "^10.2.5",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.1",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "class-validator": "^0.14.0",
    "dayjs": "^1.11.9",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "zod": "^3.22.2",
    "zod-validation-error": "^1.5.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
