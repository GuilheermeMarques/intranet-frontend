    "@types/supertest": "^2.0.16",
    "dotenv": "^16.4.5",
    "prisma": "^5.2.0",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "unplugin-swc": "^1.3.2",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^0.34.2"
